# build output
dist/
.astro/

# dependencies
node_modules/

# secrets — Resend API key etc. Never commit. See .env.example for template.
.env
.env.local
.env.*.local

# Scratch dir — anything written here is throwaway
# (screenshots, generated reports, ad-hoc captures from playwright, etc.).
tmp/

# python venv (for the test harness)
.venv/
__pycache__/
*.pyc
*.pyo

# editor / OS noise
.DS_Store
.idea/
.vscode/

# playwright MCP scratch dump (created by interactive playwright sessions)
.playwright-mcp/
.pw-cache/
