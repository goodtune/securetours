---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import FooterAfs from '../../components/FooterAfs.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import CtaBand from '../../components/CtaBand.astro';
import PageHero from '../../components/PageHero.astro';
import { matthewProfile as article } from '../../lib/articles';
---
<BaseLayout
  title={article.meta.title}
  description={article.meta.description}
  canonical="https://securetours.com.au/articles/matthew-harrison-profile/"
>

<SiteNav active="articles" />

<PageHero
  ariaLabel="Article hero"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Articles & Case Studies', href: '/articles/' },
    { label: article.crumb },
  ]}
  label={article.hero.label}
  title={article.hero.title}
  sub={article.hero.sub}
/>

<section class="section" aria-labelledby="article-heading">
  <div class="container">

    <div class="article-meta">
      {article.meta_items.map((item) => (
        <span><strong>{item.label}:</strong> {item.value}</span>
      ))}
    </div>

    <div class="article-body">
      {article.sections.map((section, i) => (
        <Fragment>
          <h2 id={i === 0 ? 'article-heading' : undefined}>{section.title}</h2>
          {section.paragraphs.map((p) => <p>{p}</p>)}
          {section.pull_quote && (
            <div class="pull-quote">
              <p>{section.pull_quote}</p>
            </div>
          )}
        </Fragment>
      ))}

      <div class="article-nav">
        <a href={article.nav.prev.href}>{article.nav.prev.label}</a>
        <a href={article.nav.next.href}>{article.nav.next.label}</a>
      </div>
    </div>
  </div>
</section>

<CtaBand
  ariaLabel="Article CTA"
  title={article.cta_band.title}
  body={article.cta_band.body}
  primary={article.cta_band.primary}
  outline={article.cta_band.outline}
/>

<FooterAfs />
<SiteFooter />

</BaseLayout>
