---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import FooterAfs from '../../components/FooterAfs.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import CtaBand from '../../components/CtaBand.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout
  title="Articles, Testimonials & Case Studies — Secure Tours & Travel"
  description="Client testimonials, case studies and insights from Secure Tours & Travel — Australia's premier secure luxury travel and event security specialists."
  canonical="https://securetours.com.au/articles/"
>

<SiteNav active="articles" />

<PageHero
  ariaLabel="Articles hero"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Articles, Testimonials & Case Studies' },
  ]}
  label="Insights & Client Stories"
  title="Articles, Testimonials & Case Studies"
  sub="Real-world insights into secure travel, event management and VIP logistics — drawn from over three decades of operational experience with AFS Group."
/>

<section class="section" aria-labelledby="content-heading">
  <div class="container">
    <h2 id="content-heading" class="sr-only">Content Library</h2>

    <div style="margin-bottom: 4rem;">
      <div class="section-heading-row">
        <div>
          <span class="section-label">What Our Clients Say</span>
          <h2 style="margin-top:0.25rem;">Testimonials & Endorsements</h2>
          <div class="gold-rule"></div>
        </div>
      </div>

      <div class="content-grid">
        <div class="testimonial-card">
          <div class="testimonial-card__header">
            <div class="testimonial-card__avatar">G</div>
            <div class="testimonial-card__author">
              <div class="testimonial-card__name">Gary O'Riordan</div>
              <div class="testimonial-card__title">Tourism Industry Consultant & Business Advisor</div>
            </div>
            <div class="testimonial-card__badge">Endorsement</div>
          </div>
          <div class="testimonial-card__body">
            <div class="testimonial-card__date">14 August 2018</div>
            <div class="testimonial-card__quote">"Secure Tours & Travel is a niche tour operator offering travel packages and itineraries, planning, coordination and booking services, as well as delivery of ground arrangements in Australia with an overarching focus on luxury, high end experiences and a clear differentiation on safety and security. This type of service offering is new to the Australian market and has good potential with high end travellers such as VIP groups, conference and event attendees, or leisure travellers who are safety and security focused."</div>
            <a class="testimonial-card__cta" href="/articles/gary-oriordan-endorsement/">Read full endorsement →</a>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-card__header">
            <div class="testimonial-card__avatar">J</div>
            <div class="testimonial-card__author">
              <div class="testimonial-card__name">Janene Rees</div>
              <div class="testimonial-card__title">Founder & Director — REES INTERNATIONAL</div>
            </div>
            <div class="testimonial-card__badge">Endorsement</div>
          </div>
          <div class="testimonial-card__body">
            <div class="testimonial-card__date">23 August 2018</div>
            <div class="testimonial-card__quote">"It gives me great pleasure to endorse Secure Tours and Travel and sister company AFS for its outstanding work practices and I believe them to be one of the best in their field… The work they carried out was of a very high standard and the client was very happy with all work done."</div>
            <a class="testimonial-card__cta" href="/articles/janene-rees-endorsement/">Read full endorsement →</a>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-card__header">
            <div class="testimonial-card__avatar">E</div>
            <div class="testimonial-card__author">
              <div class="testimonial-card__name">Event Producer</div>
              <div class="testimonial-card__title">Major Public Festival — Sydney</div>
            </div>
            <div class="testimonial-card__badge">Venue Feedback</div>
          </div>
          <div class="testimonial-card__body">
            <div class="testimonial-card__date">Available on request</div>
            <div class="testimonial-card__quote">"The AFS Group team adapted to our event's requirements each night — their familiarity with the venue and their rapid communication between teams made crowd management seamless across the full season."</div>
            <a class="testimonial-card__cta" href="/contact/">Request reference →</a>
          </div>
        </div>
      </div>
    </div>

    <div style="margin-bottom: 4rem;">
      <div class="section-heading-row">
        <div>
          <span class="section-label">Operational Experience</span>
          <h2 style="margin-top:0.25rem;">Case Studies</h2>
          <div class="gold-rule"></div>
        </div>
        <a href="/event-solutions/">View Event Solutions →</a>
      </div>

      <div class="content-grid">
        <a class="case-study-card" href="/articles/vivid-sydney/">
          <div class="case-study-card__header">
            <div class="case-study-card__label">Case Study · Public Festival Security</div>
            <div class="case-study-card__title">Vivid Sydney — Festival Security & Crowd Management</div>
          </div>
          <div class="case-study-card__body">
            <p class="case-study-card__text">One of Australia's largest public events, attracting over 3 million visitors across 23 nights. AFS Group provided crowd management, access control and VIP guest services across multiple Sydney precincts.</p>
            <span class="case-study-card__cta">Read case study →</span>
          </div>
        </a>

        <a class="case-study-card" href="/articles/carriageworks/">
          <div class="case-study-card__header">
            <div class="case-study-card__label">Case Study · Venue Security Program</div>
            <div class="case-study-card__title">Carriageworks — Multi-Event Venue Security Program</div>
          </div>
          <div class="case-study-card__body">
            <p class="case-study-card__text">Carriageworks in Sydney's Eveleigh hosts major arts, cultural and commercial events year-round. AFS Group has delivered ongoing event security across multiple productions — arts, fashion, food markets and corporate functions.</p>
            <span class="case-study-card__cta">Read case study →</span>
          </div>
        </a>

        <div class="case-study-card" style="cursor:default;">
          <div class="case-study-card__header">
            <div class="case-study-card__label">Case Study · Corporate Travel</div>
            <div class="case-study-card__title">International Sporting Delegation — Multi-City Ground Transport</div>
          </div>
          <div class="case-study-card__body">
            <p class="case-study-card__text">Secure ground transport for a 40-person international sports delegation across Sydney, Melbourne and Brisbane during a major tournament — airports, venues, accommodation and team movements coordinated end-to-end.</p>
            <span class="case-study-card__cta" style="color:var(--gold);">Coming Soon</span>
          </div>
        </div>

        <div class="case-study-card" style="cursor:default;">
          <div class="case-study-card__header">
            <div class="case-study-card__label">Case Study · Film & Television</div>
            <div class="case-study-card__title">Major Feature Production — On-Set Security & Talent Protection</div>
          </div>
          <div class="case-study-card__body">
            <p class="case-study-card__text">Providing on-set security, talent protection and location access management for a major Australian feature production — covering principal cast, location shoots and media management over an extended production schedule.</p>
            <span class="case-study-card__cta" style="color:var(--gold);">Coming Soon</span>
          </div>
        </div>
      </div>
    </div>

    <div style="margin-bottom: 4rem;">
      <span class="section-label">In Their Words</span>
      <h2 style="margin-top:0.25rem; margin-bottom:0.5rem;">Audio Interviews & Features</h2>
      <div class="gold-rule"></div>
      <p class="section-intro" style="margin-top:1rem;">Matt Harrison has been interviewed about Secure Tours & Travel and the AFS Group's unique approach to security-led travel. Listen to the interviews below.</p>

      <div class="audio-section">
        <span class="section-label">Listen</span>
        <h3>Matt Harrison — Interviews & Features</h3>
        <p>Audio interviews with Secure Tours & Travel founder Matthew Harrison discussing the vision behind the business, the Australian secure travel market, and what makes the AFS Group approach different.</p>

        <div class="audio-player-list">
          <div class="audio-player-item">
            <div class="audio-player-item__title">Matt Harrison — Secure Tours & Travel Overview</div>
            <div class="audio-player-item__meta">Interview · Duration: TBC</div>
            <div class="audio-player-item__placeholder">Audio file to be uploaded — contact us to request early access.</div>
          </div>
          <div class="audio-player-item">
            <div class="audio-player-item__title">AFS Group — 37 Years of Operational Security</div>
            <div class="audio-player-item__meta">Feature Interview · Duration: TBC</div>
            <div class="audio-player-item__placeholder">Audio file to be uploaded — contact us to request early access.</div>
          </div>
        </div>

        <p style="margin-top:1.5rem; font-size:0.825rem; color:rgba(255,255,255,0.5);">Audio files will be hosted here directly using HTML5 audio — no third-party plugins required. Subscribe for updates when new interviews are published.</p>
        <a href="/contact/" class="btn btn--outline" style="margin-top:1rem; border-color:var(--gold); color:var(--gold);">Request Early Access</a>
      </div>
    </div>

    <div>
      <span class="section-label">Insights & Opinion</span>
      <h2 style="margin-top:0.25rem; margin-bottom:0.5rem;">Articles</h2>
      <div class="gold-rule"></div>
      <p class="section-intro" style="margin-top:1rem;">Operational perspectives from the AFS Group team on security, travel management and event delivery.</p>

      <div class="content-grid" style="margin-top:2rem;">
        <a class="article-card" href="/articles/matthew-harrison-profile/" style="text-decoration:none; color:inherit;">
          <div class="article-card__header">
            <div class="article-card__category">Feature Profile</div>
            <div class="article-card__title">Matthew Harrison — AFS Solutions</div>
          </div>
          <div class="article-card__body">
            <p class="article-card__text">From working on the door at a local pub to advising and protecting high-profile clients nationally — the story of how Matthew Harrison built one of Australia's most respected secure travel and event security operations.</p>
          </div>
        </a>

        <div class="article-card">
          <div class="article-card__header">
            <div class="article-card__category">Article</div>
            <div class="article-card__title">Why Security Should Be Embedded in Event Planning — Not Bolted On</div>
            <span class="article-card__badge">Coming Soon</span>
          </div>
          <div class="article-card__body">
            <p class="article-card__text">An operational perspective on the difference between event security as an afterthought and security-first event design — and why the former consistently produces worse outcomes for organisers, guests and talent alike.</p>
          </div>
        </div>

        <div class="article-card">
          <div class="article-card__header">
            <div class="article-card__category">Article</div>
            <div class="article-card__title">The Growing Demand for Secure Inbound Tourism in Australia</div>
            <span class="article-card__badge">Coming Soon</span>
          </div>
          <div class="article-card__body">
            <p class="article-card__text">High-end international travellers are increasingly seeking operators who can guarantee both luxury and safety. How Australia's inbound tourism sector is responding — and what Secure Tours & Travel is doing differently.</p>
          </div>
        </div>

        <div class="article-card">
          <div class="article-card__header">
            <div class="article-card__category">Article</div>
            <div class="article-card__title">STAT Accreditation: Raising the Safety Bar for Australian Tourism Operators</div>
            <span class="article-card__badge">Coming Soon</span>
          </div>
          <div class="article-card__body">
            <p class="article-card__text">What STAT Accreditation means, why it matters to international tourism wholesalers, and how it is changing the way Australian operators communicate their safety and security standards to the global market.</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<CtaBand
  ariaLabel="Articles CTA"
  title="Have a Story to Share?"
  body="If you are a past client willing to provide a testimonial or case study contribution, we would love to hear from you. We handle all content with confidentiality in mind."
  primary={{ label: 'Get in Touch', href: '/contact/' }}
  outline={{ label: 'View Event Solutions', href: '/event-solutions/' }}
/>

<FooterAfs />
<SiteFooter />

<style is:global>
  .testimonial-card {
    background: var(--white);
    border: 1px solid var(--gray-300);
    border-radius: var(--radius);
    overflow: hidden;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
  }
  .testimonial-card:hover { border-color: var(--gold); box-shadow: var(--shadow); }
  .testimonial-card__header {
    background: var(--navy);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .testimonial-card__avatar {
    width: 48px;
    height: 48px;
    background: var(--gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--navy);
    flex-shrink: 0;
  }
  .testimonial-card__author { flex: 1; }
  .testimonial-card__name {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--white);
  }
  .testimonial-card__title {
    font-size: 0.775rem;
    color: rgba(255,255,255,0.6);
    margin-top: 0.15rem;
  }
  .testimonial-card__badge {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(184,149,42,0.12);
    border: 1px solid rgba(184,149,42,0.3);
    border-radius: 2px;
    padding: 0.2rem 0.5rem;
  }
  .testimonial-card__body { padding: 1.75rem 2rem; flex: 1; }
  .testimonial-card__date {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }
  .testimonial-card__quote {
    font-size: 0.9375rem;
    color: var(--gray-700);
    font-style: italic;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    border-left: 3px solid var(--gold);
    padding-left: 1rem;
  }
  .testimonial-card__cta {
    font-size: 0.825rem;
    font-weight: 600;
    color: var(--navy);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .case-study-card {
    background: var(--white);
    border: 1px solid var(--gray-300);
    border-radius: var(--radius);
    overflow: hidden;
    transition: var(--transition);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }
  .case-study-card:hover { border-color: var(--gold); box-shadow: var(--shadow); }
  .case-study-card__header { background: var(--navy); padding: 2rem; }
  .case-study-card__label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }
  .case-study-card__title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: rgba(255,255,255,0.95);
    line-height: 1.4;
  }
  .case-study-card__body { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; }
  .case-study-card__text { font-size: 0.875rem; color: var(--gray-700); flex: 1; margin-bottom: 1rem; }
  .case-study-card__cta {
    font-size: 0.825rem;
    font-weight: 600;
    color: var(--navy);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-card {
    background: var(--white);
    border: 1px solid var(--gray-300);
    border-radius: var(--radius);
    overflow: hidden;
    transition: var(--transition);
  }
  .article-card:hover { border-color: var(--gold); box-shadow: var(--shadow); }
  .article-card__header { background: var(--navy); padding: 1.75rem 2rem; }
  .article-card__category {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.6rem;
  }
  .article-card__title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: rgba(255,255,255,0.9);
    line-height: 1.4;
  }
  .article-card__badge {
    display: inline-block;
    background: rgba(184,149,42,0.15);
    border: 1px solid rgba(184,149,42,0.4);
    color: var(--gold);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 2px;
    margin-top: 0.75rem;
  }
  .article-card__body { padding: 1.5rem; }
  .article-card__text { font-size: 0.875rem; color: var(--gray-700); margin: 0; }

  .audio-section {
    background: var(--navy-dark);
    border-radius: var(--radius);
    padding: 3rem;
    margin-top: 3rem;
    color: var(--white);
  }
  .audio-section .section-label { color: var(--gold); }
  .audio-section h3 {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: var(--white);
    margin-bottom: 1rem;
  }
  .audio-section p { color: rgba(255,255,255,0.75); margin-bottom: 1.5rem; }

  .audio-player-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .audio-player-item {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(184,149,42,0.2);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
  }
  .audio-player-item__title {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--white);
    margin-bottom: 0.3rem;
  }
  .audio-player-item__meta {
    font-size: 0.775rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.75rem;
  }
  .audio-player-item__placeholder {
    background: rgba(255,255,255,0.04);
    border: 1px dashed rgba(184,149,42,0.3);
    border-radius: 2px;
    padding: 0.75rem 1rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
    font-style: italic;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .section-heading-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .section-heading-row h2 { margin: 0; }
  .section-heading-row > a {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 2px;
    white-space: nowrap;
  }
</style>

</BaseLayout>
