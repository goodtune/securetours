---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import FooterAfs from '../../components/FooterAfs.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import CtaBand from '../../components/CtaBand.astro';
import PageHero from '../../components/PageHero.astro';
import { articlesIndex as page } from '../../lib/pages';
---
<BaseLayout
  title={page.meta.title}
  description={page.meta.description}
  canonical="https://securetours.com.au/articles/"
>

<SiteNav active="articles" />

<PageHero
  ariaLabel="Articles hero"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Articles, Testimonials & Case Studies' },
  ]}
  label={page.hero.label}
  title={page.hero.title}
  sub={page.hero.sub}
/>

<section class="section" aria-labelledby="content-heading">
  <div class="container">
    <h2 id="content-heading" class="sr-only">{page.library_heading}</h2>

    <div style="margin-bottom: 4rem;">
      <div class="section-heading-row">
        <div>
          <span class="section-label">{page.testimonials.label}</span>
          <h2 style="margin-top:0.25rem;">{page.testimonials.title}</h2>
          <div class="gold-rule"></div>
        </div>
      </div>

      <div class="content-grid">
        {page.testimonials.cards.map((card) => (
          <div class="testimonial-card">
            <div class="testimonial-card__header">
              <div class="testimonial-card__avatar">{card.avatar}</div>
              <div class="testimonial-card__author">
                <div class="testimonial-card__name">{card.name}</div>
                <div class="testimonial-card__title">{card.title}</div>
              </div>
              <div class="testimonial-card__badge">{card.badge}</div>
            </div>
            <div class="testimonial-card__body">
              <div class="testimonial-card__date">{card.date}</div>
              <div class="testimonial-card__quote">{card.quote}</div>
              <a class="testimonial-card__cta" href={card.cta_href}>{card.cta_label}</a>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div style="margin-bottom: 4rem;">
      <div class="section-heading-row">
        <div>
          <span class="section-label">{page.case_studies.label}</span>
          <h2 style="margin-top:0.25rem;">{page.case_studies.title}</h2>
          <div class="gold-rule"></div>
        </div>
        <a href={page.case_studies.view_link.href}>{page.case_studies.view_link.label}</a>
      </div>

      <div class="content-grid">
        {page.case_studies.cards.map((card) =>
          card.href ? (
            <a class="case-study-card" href={card.href}>
              <div class="case-study-card__header">
                <div class="case-study-card__label">{card.label}</div>
                <div class="case-study-card__title">{card.title}</div>
              </div>
              <div class="case-study-card__body">
                <p class="case-study-card__text">{card.text}</p>
                <span class="case-study-card__cta">{card.cta}</span>
              </div>
            </a>
          ) : (
            <div class="case-study-card" style="cursor:default;">
              <div class="case-study-card__header">
                <div class="case-study-card__label">{card.label}</div>
                <div class="case-study-card__title">{card.title}</div>
              </div>
              <div class="case-study-card__body">
                <p class="case-study-card__text">{card.text}</p>
                <span class="case-study-card__cta" style="color:var(--gold);">{card.cta}</span>
              </div>
            </div>
          ),
        )}
      </div>
    </div>

    <div style="margin-bottom: 4rem;">
      <span class="section-label">{page.audio.label}</span>
      <h2 style="margin-top:0.25rem; margin-bottom:0.5rem;">{page.audio.title}</h2>
      <div class="gold-rule"></div>
      <p class="section-intro" style="margin-top:1rem;">{page.audio.intro}</p>

      <div class="audio-section">
        <span class="section-label">{page.audio.panel.label}</span>
        <h3>{page.audio.panel.title}</h3>
        <p>{page.audio.panel.body}</p>

        <div class="audio-player-list">
          {page.audio.panel.items.map((item) => (
            <div class="audio-player-item">
              <div class="audio-player-item__title">{item.title}</div>
              <div class="audio-player-item__meta">{item.meta}</div>
              <div class="audio-player-item__placeholder">{item.placeholder}</div>
            </div>
          ))}
        </div>

        <p style="margin-top:1.5rem; font-size:0.825rem; color:rgba(255,255,255,0.5);">{page.audio.panel.note}</p>
        <a href="/contact/" class="btn btn--outline" style="margin-top:1rem; border-color:var(--gold); color:var(--gold);">{page.audio.panel.cta_label}</a>
      </div>
    </div>

    <div>
      <span class="section-label">{page.articles.label}</span>
      <h2 style="margin-top:0.25rem; margin-bottom:0.5rem;">{page.articles.title}</h2>
      <div class="gold-rule"></div>
      <p class="section-intro" style="margin-top:1rem;">{page.articles.intro}</p>

      <div class="content-grid" style="margin-top:2rem;">
        {page.articles.cards.map((card) =>
          card.href ? (
            <a class="article-card" href={card.href} style="text-decoration:none; color:inherit;">
              <div class="article-card__header">
                <div class="article-card__category">{card.category}</div>
                <div class="article-card__title">{card.title}</div>
              </div>
              <div class="article-card__body">
                <p class="article-card__text">{card.text}</p>
              </div>
            </a>
          ) : (
            <div class="article-card">
              <div class="article-card__header">
                <div class="article-card__category">{card.category}</div>
                <div class="article-card__title">{card.title}</div>
                {card.badge && <span class="article-card__badge">{card.badge}</span>}
              </div>
              <div class="article-card__body">
                <p class="article-card__text">{card.text}</p>
              </div>
            </div>
          ),
        )}
      </div>
    </div>

  </div>
</section>

<CtaBand
  ariaLabel="Articles CTA"
  title={page.cta_band.title}
  body={page.cta_band.body}
  primary={page.cta_band.primary}
  outline={page.cta_band.outline}
/>

<FooterAfs />
<SiteFooter />

<style is:global>
  .testimonial-card {
    background: var(--white);
    border: 1px solid var(--gray-300);
    border-radius: var(--radius);
    overflow: hidden;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
  }
  .testimonial-card:hover { border-color: var(--gold); box-shadow: var(--shadow); }
  .testimonial-card__header {
    background: var(--navy);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .testimonial-card__avatar {
    width: 48px;
    height: 48px;
    background: var(--gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--navy);
    flex-shrink: 0;
  }
  .testimonial-card__author { flex: 1; }
  .testimonial-card__name {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--white);
  }
  .testimonial-card__title {
    font-size: 0.775rem;
    color: rgba(255,255,255,0.6);
    margin-top: 0.15rem;
  }
  .testimonial-card__badge {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(184,149,42,0.12);
    border: 1px solid rgba(184,149,42,0.3);
    border-radius: 2px;
    padding: 0.2rem 0.5rem;
  }
  .testimonial-card__body { padding: 1.75rem 2rem; flex: 1; }
  .testimonial-card__date {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }
  .testimonial-card__quote {
    font-size: 0.9375rem;
    color: var(--gray-700);
    font-style: italic;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    border-left: 3px solid var(--gold);
    padding-left: 1rem;
  }
  .testimonial-card__cta {
    font-size: 0.825rem;
    font-weight: 600;
    color: var(--navy);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .case-study-card {
    background: var(--white);
    border: 1px solid var(--gray-300);
    border-radius: var(--radius);
    overflow: hidden;
    transition: var(--transition);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }
  .case-study-card:hover { border-color: var(--gold); box-shadow: var(--shadow); }
  .case-study-card__header { background: var(--navy); padding: 2rem; }
  .case-study-card__label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }
  .case-study-card__title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: rgba(255,255,255,0.95);
    line-height: 1.4;
  }
  .case-study-card__body { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; }
  .case-study-card__text { font-size: 0.875rem; color: var(--gray-700); flex: 1; margin-bottom: 1rem; }
  .case-study-card__cta {
    font-size: 0.825rem;
    font-weight: 600;
    color: var(--navy);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-card {
    background: var(--white);
    border: 1px solid var(--gray-300);
    border-radius: var(--radius);
    overflow: hidden;
    transition: var(--transition);
  }
  .article-card:hover { border-color: var(--gold); box-shadow: var(--shadow); }
  .article-card__header { background: var(--navy); padding: 1.75rem 2rem; }
  .article-card__category {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.6rem;
  }
  .article-card__title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: rgba(255,255,255,0.9);
    line-height: 1.4;
  }
  .article-card__badge {
    display: inline-block;
    background: rgba(184,149,42,0.15);
    border: 1px solid rgba(184,149,42,0.4);
    color: var(--gold);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 2px;
    margin-top: 0.75rem;
  }
  .article-card__body { padding: 1.5rem; }
  .article-card__text { font-size: 0.875rem; color: var(--gray-700); margin: 0; }

  .audio-section {
    background: var(--navy-dark);
    border-radius: var(--radius);
    padding: 3rem;
    margin-top: 3rem;
    color: var(--white);
  }
  .audio-section .section-label { color: var(--gold); }
  .audio-section h3 {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: var(--white);
    margin-bottom: 1rem;
  }
  .audio-section p { color: rgba(255,255,255,0.75); margin-bottom: 1.5rem; }

  .audio-player-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .audio-player-item {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(184,149,42,0.2);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
  }
  .audio-player-item__title {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--white);
    margin-bottom: 0.3rem;
  }
  .audio-player-item__meta {
    font-size: 0.775rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.75rem;
  }
  .audio-player-item__placeholder {
    background: rgba(255,255,255,0.04);
    border: 1px dashed rgba(184,149,42,0.3);
    border-radius: 2px;
    padding: 0.75rem 1rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
    font-style: italic;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .section-heading-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .section-heading-row h2 { margin: 0; }
  .section-heading-row > a {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 2px;
    white-space: nowrap;
  }
</style>

</BaseLayout>
