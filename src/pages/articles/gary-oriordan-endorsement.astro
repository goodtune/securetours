---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import FooterAfs from '../../components/FooterAfs.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import CtaBand from '../../components/CtaBand.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout
  title="Industry Endorsement — Gary O'Riordan | Secure Tours & Travel"
  description="Industry endorsement of Secure Tours & Travel by Gary O'Riordan, senior tourism industry professional and business consultancy principal."
  canonical="https://securetours.com.au/articles/gary-oriordan-endorsement/"
>

<SiteNav active="articles" />

<PageHero
  ariaLabel="Testimonial hero"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Articles & Testimonials', href: '/articles/' },
    { label: "Gary O'Riordan" },
  ]}
  label="Industry Endorsement · 2018"
  title="Gary O'Riordan"
  sub="Senior tourism industry professional and business consultancy principal — endorsing Secure Tours & Travel and the unique service proposition it brings to the Australian and inbound tourism market."
/>

<section class="section" aria-labelledby="testimonial-heading">
  <div class="container">

    <div class="context-block">
      <h3>About this endorsement</h3>
      <p>Gary O'Riordan is a senior tourism industry professional with extensive experience in senior roles across the Travel & Tourism industry, and the principal of his own tourism business consultancy. Gary assisted Matthew Harrison in the development of the Secure Tours & Travel concept and business plan, and introduced the business to key tourism organisations including Tourism Australia and the Australian Tourism Export Council (ATEC).</p>
    </div>

    <div class="testimonial-body">
      <h2 id="testimonial-heading" class="sr-only">Endorsement Letter</h2>

      <div class="endorsement-card">
        <div class="endorsement-card__header">
          <div class="endorsement-card__avatar">G</div>
          <div>
            <div class="endorsement-card__author-name">Gary O'Riordan</div>
            <div class="endorsement-card__author-title">Tourism Industry Consultant & Business Advisor</div>
          </div>
        </div>
        <div class="endorsement-card__body">
          <div class="endorsement-card__date">14 August 2018</div>
          <div class="endorsement-card__letter">
            <p>To whom it may concern,</p>
            <p>This letter is an endorsement for Mr Matthew Harrison and his business Secure Tours & Travel.</p>
            <p>I have known Matt for many years and have also been involved in the development of his new business venture — Secure Tours & Travel.</p>
            <p>Having held many senior roles in the Travel & Tourism Industry and recently running my own tourism business consultancy, I also assisted Matthew with the development of the concept and business plan for Secure Tours & Travel.</p>
            <p>The business has been introduced to key tourism organisations such as Tourism Australia and the Australian Tourism Export Council. The business has participated in key trade expos to promote its unique services and product offering in the Australian and inbound tourism market.</p>
            <p>Secure Tours & Travel is a niche tour operator offering travel packages and itineraries, planning, coordination and booking services, as well as delivery of ground arrangements in Australia with an overarching focus on luxury, high end experiences and a clear differentiation on safety and security.</p>
            <p>This type of service offering is new to the Australian market and has good potential with high end travellers such as VIP groups, conference and event attendees, or leisure travellers who are safety and security focused.</p>
            <p>I wish Matthew the very best with his business into the future.</p>
          </div>
          <div class="endorsement-card__salutation">Yours sincerely,<br />Gary O'Riordan</div>
          <div class="endorsement-card__download">
            <a href="/assets/downloads/endorsement-gary-oriordan-2018.pdf" target="_blank" rel="noopener">📄 Download original letter (PDF)</a>
            <span>62 KB</span>
          </div>
        </div>
      </div>

      <div class="article-nav">
        <a href="/articles/">← Back to Articles & Testimonials</a>
        <a href="/articles/vivid-sydney/">Vivid Sydney Case Study →</a>
      </div>
    </div>
  </div>
</section>

<CtaBand
  ariaLabel="Testimonial CTA"
  title="Want to Know More?"
  body="We are happy to provide additional references and discuss our experience with prospective clients in confidence."
  primary={{ label: 'Get in Touch', href: '/contact/' }}
  outline={{ label: 'View Resources', href: '/resources/' }}
/>

<FooterAfs />
<SiteFooter />

</BaseLayout>
