---
// Sveltia CMS admin shell. Entirely client-side: the CMS reads
// /admin/config.yml (generated by ./config.yml.ts) and commits content
// changes to GitHub. Excluded from the sitemap and robots.txt.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Content Manager — Secure Tours &amp; Travel</title>
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  </head>
  <body>
    <!--
      Pinned deliberately: unpinned `latest` shipped same-day startup
      regressions (sveltia-cms#821 — v0.170.6/0.170.7 hang at the loading
      screen; 0.170.5 is known good). To upgrade, bump the version here,
      check the Sveltia release notes/issues, and test /admin on staging.
    -->
    <script is:inline src="https://unpkg.com/@sveltia/cms@0.170.5/dist/sveltia-cms.js"></script>
  </body>
</html>
