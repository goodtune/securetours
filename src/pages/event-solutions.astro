---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import FooterAfs from '../components/FooterAfs.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CtaBand from '../components/CtaBand.astro';
import PageHero from '../components/PageHero.astro';
import { eventSolutions as page } from '../lib/pages';
---
<BaseLayout
  title={page.meta.title}
  description={page.meta.description}
  canonical="https://securetours.com.au/event-solutions/"
>

<SiteNav active="event-solutions" />

<PageHero
  ariaLabel="Event Solutions hero"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Event Solutions' },
  ]}
  label={page.hero.label}
  title={page.hero.title}
  sub={page.hero.sub}
/>

<section class="section" aria-labelledby="event-lead-heading">
  <div class="container">
    <div class="event-lead-grid">
      <div>
        <span class="section-label">{page.lead.label}</span>
        <h2 id="event-lead-heading">{page.lead.title}</h2>
        <div class="gold-rule"></div>
        <p class="service-lead">{page.lead.lead}</p>
        {page.lead.paragraphs.map((p) => <p>{p}</p>)}
        <a href="/contact/" class="btn btn--primary" style="margin-top:1.5rem;">{page.lead.cta_label}</a>
      </div>
      <div>
        <div class="event-credential">
          <h3>{page.lead.credentials.title}</h3>
          <ul>
            {page.lead.credentials.items.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section section--alt" aria-labelledby="event-services-heading">
  <div class="container">
    <span class="section-label">{page.offerings.label}</span>
    <h2 id="event-services-heading">{page.offerings.title}</h2>
    <div class="gold-rule"></div>
    <p class="section-intro">{page.offerings.intro}</p>

    <div class="events-grid">
      {page.offerings.events.map((e) => (
        <article class="event-card">
          <div class="event-card__icon">{e.icon}</div>
          <h3 class="event-card__title">{e.title}</h3>
          <p class="event-card__text">{e.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section" aria-labelledby="film-tv-heading">
  <div class="container">
    <span class="section-label">{page.film_tv.label}</span>
    <h2 id="film-tv-heading">{page.film_tv.title}</h2>
    <div class="gold-rule"></div>
    <p class="section-intro">{page.film_tv.intro}</p>

    <div class="film-tv-section">
      <span class="section-label">{page.film_tv.panel.label}</span>
      <h3>{page.film_tv.panel.title}</h3>
      {page.film_tv.panel.paragraphs.map((p, i) => (
        <p style={i > 0 ? 'margin-top:1rem;' : undefined}>{p}</p>
      ))}

      <div class="film-tv-grid">
        {page.film_tv.panel.capabilities.map((c) => (
          <div class="film-tv-item">
            <h4>{c.title}</h4>
            <p>{c.body}</p>
          </div>
        ))}
      </div>

      <a href="/contact/" class="btn btn--outline" style="margin-top:2rem; border-color:var(--gold); color:var(--gold);">{page.film_tv.panel.cta_label}</a>
    </div>
  </div>
</section>

<section class="section section--alt" aria-labelledby="services-list-heading">
  <div class="container">
    <span class="section-label">{page.portfolio.label}</span>
    <h2 id="services-list-heading">{page.portfolio.title}</h2>
    <div class="gold-rule"></div>
    <p class="section-intro">{page.portfolio.intro}</p>

    <div class="services-two-col" style="margin-top:2rem;">
      {page.portfolio.items.map((item) => <div class="service-list-item">{item}</div>)}
    </div>
  </div>
</section>

<section class="section" aria-labelledby="why-events-heading">
  <div class="container">
    <span class="section-label">{page.differentiators.label}</span>
    <h2 id="why-events-heading">{page.differentiators.title}</h2>
    <div class="gold-rule"></div>

    <div class="differentiator-grid">
      {page.differentiators.items.map((d) => (
        <div class="diff-item">
          <div class="diff-item__icon">{d.icon}</div>
          <div class="diff-item__body">
            <h4>{d.title}</h4>
            <p>{d.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section section--alt" aria-labelledby="case-studies-heading">
  <div class="container">
    <span class="section-label">{page.case_studies.label}</span>
    <h2 id="case-studies-heading">{page.case_studies.title}</h2>
    <div class="gold-rule"></div>
    <p class="section-intro">{page.case_studies.intro}</p>

    <div class="case-study-grid">
      {page.case_studies.cards.map((card) =>
        card.href ? (
          <a class="case-study-card" href={card.href}>
            <div class="case-study-card__header">
              <div class="case-study-card__label">{card.label}</div>
              <div class="case-study-card__title">{card.title}</div>
            </div>
            <div class="case-study-card__body">
              <p class="case-study-card__text">{card.text}</p>
              <span class="case-study-card__cta">{card.cta}</span>
            </div>
          </a>
        ) : (
          <div class="case-study-card" style="cursor:default;">
            <div class="case-study-card__header">
              <div class="case-study-card__label">{card.label}</div>
              <div class="case-study-card__title">{card.title}</div>
            </div>
            <div class="case-study-card__body">
              <p class="case-study-card__text">{card.text}</p>
              <span class="case-study-card__cta" style="color:var(--gold);">{card.cta}</span>
            </div>
          </div>
        ),
      )}
    </div>

    <div style="margin-top:2rem; text-align:center;">
      <a href="/articles/" class="btn btn--outline-navy">{page.case_studies.all_link_label}</a>
    </div>
  </div>
</section>

<CtaBand
  ariaLabel="Event Solutions CTA"
  title={page.cta_band.title}
  body={page.cta_band.body}
  primary={page.cta_band.primary}
  outline={page.cta_band.outline}
/>

<FooterAfs />
<SiteFooter />

</BaseLayout>
