---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import FooterAfs from '../components/FooterAfs.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CtaBand from '../components/CtaBand.astro';
import PageHero from '../components/PageHero.astro';

const events = [
  { icon: '🏢', title: 'Corporate Events & Functions', body: 'Board meetings, investor presentations, product launches and gala dinners. Discreet security presence, executive guest management, VIP arrival coordination and confidential protocol compliance for high-value corporate gatherings. Our personnel understand the discretion expected in high-stakes corporate environments.' },
  { icon: '🏟️', title: 'Sporting Events', body: 'From national league fixtures to major international sporting tournaments, our teams manage crowd flow, VIP access control, athlete and official escort, and post-event egress. Experienced across football, rugby, cricket, tennis and aquatic events. We coordinate with venue operators to deliver seamless, safe sporting environments.' },
  { icon: '🎵', title: 'Concerts & Live Entertainment', body: 'Venue security, backstage access management, artist transfer coordination and fan safety protocols for live music events, festivals and theatre productions. We work with touring production companies and venue operators to deliver safe, seamless events — protecting talent, crew and audiences alike.' },
  { icon: '✈️', title: 'Group Travel Management', body: 'Coordinated secure travel for corporate delegations, sporting teams, school groups and tour parties. End-to-end logistics from departure to return — including airport transfers, accommodation liaisons, multilingual chaperones and real-time incident support. One point of contact, complete accountability.' },
  { icon: '🎙️', title: 'Conferences & Exhibitions', body: 'Badge verification, access control, speaker and delegate protection, sensitive materials handling and emergency response planning for conferences, trade exhibitions and government summits. Scaled to the size and sensitivity of your event. We have supported major international conference delegations across Sydney, Melbourne and Brisbane.' },
  { icon: '🎓', title: 'School Tours & Group Excursions', body: 'S.T.A.G.E. — School Tours And Group Excursions. Specialist support for educational institutions managing large student groups, including risk assessment, licensed chaperones, emergency protocols and transport coordination. Safety embedded at every layer. Our vetted personnel are experienced in managing unaccompanied minors and student cohorts.' },
  { icon: '🌟', title: 'Public Festivals & Cultural Events', body: 'Major public events, cultural festivals, light shows and outdoor spectacles require layered security planning and fluid crowd management. Our teams coordinate access points, manage crowd density, liaise with emergency services and ensure that large public gatherings are safe, orderly and memorable for all the right reasons.' },
  { icon: '🏛️', title: 'Government & Diplomatic Events', body: 'Protocol management, close personal protection, secure transport and access control for government functions, diplomatic receptions and high-profile official visits. Our teams understand the sensitivities involved and operate with the highest levels of discretion, coordinating with official agencies as required.' },
  { icon: '🚤', title: 'Marine & Waterfront Events', body: 'Waterfront events, vessel charters and harbour events present unique security and logistics challenges. Our teams coordinate marine transfers, vessel boarding security, waterfront perimeter management and VIP access for yacht events, harbour cruises and waterfront functions.' },
];

const filmTvCapabilities = [
  { title: 'Talent Protection', body: 'Close personal protection for principal cast, directors and high-profile crew. Discreet, professional and production-schedule aware.' },
  { title: 'Location Security', body: 'Perimeter management, access control and unauthorised entry prevention for location shoots. Coordination with local councils and police where required.' },
  { title: 'Set Access Control', body: 'Credentialing and access management for cast, crew, contractors and visitors. Ensuring only authorised personnel access restricted areas.' },
  { title: 'Media Management', body: 'Managing media access and preventing unauthorised photography or filming of talent, sets or pre-release content. Coordinated with your publicity team.' },
  { title: 'Equipment & Asset Security', body: 'Overnight and transit security for high-value production equipment, props and sensitive materials. Monitored transport and secure storage coordination.' },
  { title: 'Production Travel', body: 'Secure transport and chaperone services for talent movement between sets, hotels, airports and events. Discreet vehicles and licensed drivers.' },
];

const servicesList = [
  'Close Personal Protection',
  'Secure Escort Services',
  'Crowd Control & Crowd Management',
  'Access Control & Credentialing',
  'Event Security Planning & Risk Assessment',
  'Corporate Security',
  'STAT Accreditation (Tourism Security Assessment)',
  'Personal Concierge Services',
  'Chaperone & Escort Services',
  'Transport Logistics Coordination',
  'Security Management & Incident Response',
  'Safety Management Planning',
  'Medics + First Aid Coordination',
  'COVID Compliance Protocols',
  'Travel Safety Briefings & Updates',
  'Multilingual Event Support',
  'VIP & Dignitary Management',
  'Emergency Egress Planning',
  'Unaccompanied Minor Supervision',
  'On-Set Film & TV Security',
];

const differentiators = [
  { icon: '🛡️', title: 'Licensed Security Embedded in Your Team', body: 'Unlike event coordinators who contract security separately, our licensed personnel are integrated into the planning and delivery of your event from day one — not added as an afterthought.' },
  { icon: '📋', title: 'Formal Risk Assessment — Every Event', body: 'Every event begins with a written risk assessment covering venue security, crowd density, access points, medical coverage requirements and emergency egress. Documented, signed and rehearsed before your event begins.' },
  { icon: '👥', title: 'Crowd Management Expertise', body: 'Our crowd controllers are trained in behavioural assessment, de-escalation and emergency response. We design crowd flow to prevent bottlenecks and manage incidents before they escalate to crises.' },
  { icon: '🔑', title: 'VIP Access Control', body: 'Tiered access management for talent, officials, media and sponsors. Our teams coordinate with venue operators to enforce access protocols while ensuring VIP guests receive seamless, dignified service.' },
  { icon: '🌐', title: 'Multilingual Event Support', body: 'For events hosting international guests, delegates or athletes, our multilingual personnel provide direct communication support in English, Mandarin and additional languages — reducing misunderstandings and enhancing guest experience.' },
  { icon: '🗺️', title: 'National Footprint', body: 'Operational capacity across New South Wales, Queensland and Victoria, with access to affiliate networks for events in other states and territories. One point of contact, national reach.' },
  { icon: '🏅', title: 'STAT Accreditation', body: 'Our STAT Accreditation program provides an independent, objective safety and security assessment for tourism and hospitality providers — giving event organisers and international wholesale partners a recognised, standardised risk rating.' },
  { icon: '⚕️', title: 'Health & Safety Integration', body: 'We coordinate medics and first aid provision, work health and safety planning, COVID compliance protocols and emergency medical response as part of our event security brief — not as a separate engagement.' },
];
---
<BaseLayout
  title="Event Solutions — Secure Tours & Travel"
  description="Professional event management with licensed security personnel embedded at every level. Corporate functions, sporting events, concerts, film & TV production, group travel and conference support across Australia."
  canonical="https://securetours.com.au/event-solutions/"
>

<SiteNav active="event-solutions" />

<PageHero
  ariaLabel="Event Solutions hero"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Event Solutions' },
  ]}
  label="Corporate · Sporting · Entertainment · Film & TV · Group"
  title="Event Solutions"
  sub="From intimate corporate functions to large-scale sporting spectacles and major film productions — AFS Group brings licensed security expertise, crowd management experience and white-glove hospitality to every event we support."
/>

<section class="section" aria-labelledby="event-lead-heading">
  <div class="container">
    <div class="event-lead-grid">
      <div>
        <span class="section-label">Our Capability</span>
        <h2 id="event-lead-heading">Security-First Event Management</h2>
        <div class="gold-rule"></div>
        <p class="service-lead">Secure Tours & Travel, as part of the Australian Frontline Solutions (AFS) Group, brings over 37 years of operational security and event management experience to every brief we accept. Our teams are not an add-on to your event — they are embedded within it.</p>
        <p>Whether you are managing a delegation of corporate guests at a major sporting final, protecting a headline act on a national tour, coordinating the safe movement of hundreds of conference delegates across a city, or providing on-set security for a major film or television production, our licensed personnel provide the operational backbone your event demands.</p>
        <p>We operate nationally, with established capabilities across NSW, QLD and VIC, and access to partner networks for international assignments.</p>
        <a href="/contact/" class="btn btn--primary" style="margin-top:1.5rem;">Discuss Your Event</a>
      </div>
      <div>
        <div class="event-credential">
          <h3>AFS Group Credentials</h3>
          <ul>
            <li>Security Master Licence holder — licensed operator</li>
            <li>Established 1989 — 37 years of operational experience</li>
            <li>National footprint: NSW · QLD · VIC</li>
            <li>Licensed crowd controllers and close protection officers</li>
            <li>Risk assessment and event safety planning</li>
            <li>Multilingual personnel — English, Mandarin and more</li>
            <li>24/7 operational support and incident management</li>
            <li>Integrated transport and logistics coordination</li>
            <li>STAT Accreditation — independent safety and security assessment</li>
            <li>Medics + First Aid coordination on-site</li>
            <li>COVID compliance protocols available</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section section--alt" aria-labelledby="event-services-heading">
  <div class="container">
    <span class="section-label">What We Deliver</span>
    <h2 id="event-services-heading">Event Service Offerings</h2>
    <div class="gold-rule"></div>
    <p class="section-intro">Our event solutions span the full spectrum — from intimate executive functions requiring discreet protection to mass-attendance public events requiring full crowd and access management.</p>

    <div class="events-grid">
      {events.map((e) => (
        <article class="event-card">
          <div class="event-card__icon">{e.icon}</div>
          <h3 class="event-card__title">{e.title}</h3>
          <p class="event-card__text">{e.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section" aria-labelledby="film-tv-heading">
  <div class="container">
    <span class="section-label">Industry Specialist</span>
    <h2 id="film-tv-heading">Film & Television Security</h2>
    <div class="gold-rule"></div>
    <p class="section-intro">AFS Group has established specialist capabilities for the Australian film and television industry — a sector with unique demands around talent security, location access, set protection and media management.</p>

    <div class="film-tv-section">
      <span class="section-label">Film + TV Specialist</span>
      <h3>On-Set Security & Production Support</h3>
      <p>From single-day shoots to major feature film productions, our licensed security personnel integrate with your production team — managing talent protection, location security, crew safety and unauthorised access prevention. We understand the demands of production schedules and operate to minimise disruption while maintaining a secure working environment.</p>
      <p style="margin-top:1rem;">Our Film + TV security team has experience supporting productions across Sydney, regional NSW, and interstate — including location shoots in public spaces, heritage venues, and high-security environments requiring close coordination with local authorities.</p>

      <div class="film-tv-grid">
        {filmTvCapabilities.map((c) => (
          <div class="film-tv-item">
            <h4>{c.title}</h4>
            <p>{c.body}</p>
          </div>
        ))}
      </div>

      <a href="/contact/" class="btn btn--outline" style="margin-top:2rem; border-color:var(--gold); color:var(--gold);">Discuss Production Requirements</a>
    </div>
  </div>
</section>

<section class="section section--alt" aria-labelledby="services-list-heading">
  <div class="container">
    <span class="section-label">Comprehensive Capabilities</span>
    <h2 id="services-list-heading">Full Event Services Portfolio</h2>
    <div class="gold-rule"></div>
    <p class="section-intro">AFS Group provides the following services across all event types. Our licensed personnel can be deployed individually or as integrated teams depending on event scale and risk profile.</p>

    <div class="services-two-col" style="margin-top:2rem;">
      {servicesList.map((item) => <div class="service-list-item">{item}</div>)}
    </div>
  </div>
</section>

<section class="section" aria-labelledby="why-events-heading">
  <div class="container">
    <span class="section-label">Why Choose AFS</span>
    <h2 id="why-events-heading">What Sets Our Event Teams Apart</h2>
    <div class="gold-rule"></div>

    <div class="differentiator-grid">
      {differentiators.map((d) => (
        <div class="diff-item">
          <div class="diff-item__icon">{d.icon}</div>
          <div class="diff-item__body">
            <h4>{d.title}</h4>
            <p>{d.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section section--alt" aria-labelledby="case-studies-heading">
  <div class="container">
    <span class="section-label">Operational Experience</span>
    <h2 id="case-studies-heading">Events We Have Supported</h2>
    <div class="gold-rule"></div>
    <p class="section-intro">Our teams have delivered security and logistics support at some of Australia's most high-profile events. Read how we operate in the field.</p>

    <div class="case-study-grid">
      <a class="case-study-card" href="/articles/vivid-sydney/">
        <div class="case-study-card__header">
          <div class="case-study-card__label">Case Study · Public Festival</div>
          <div class="case-study-card__title">Vivid Sydney — Festival Security & Crowd Management</div>
        </div>
        <div class="case-study-card__body">
          <p class="case-study-card__text">One of Australia's largest public events, attracting over 3 million visitors across 23 days. AFS Group provided crowd management, access control and VIP guest services across multiple Vivid Sydney precincts.</p>
          <span class="case-study-card__cta">Read case study →</span>
        </div>
      </a>

      <a class="case-study-card" href="/articles/carriageworks/">
        <div class="case-study-card__header">
          <div class="case-study-card__label">Case Study · Venue Security</div>
          <div class="case-study-card__title">Carriageworks — Multi-Event Venue Security Program</div>
        </div>
        <div class="case-study-card__body">
          <p class="case-study-card__text">Carriageworks in Sydney's Eveleigh hosts major arts, cultural and commercial events year-round. AFS Group has delivered event security across multiple productions at this landmark venue.</p>
          <span class="case-study-card__cta">Read case study →</span>
        </div>
      </a>

      <div class="case-study-card" style="cursor:default;">
        <div class="case-study-card__header">
          <div class="case-study-card__label">Case Study · Corporate Events</div>
          <div class="case-study-card__title">International Sporting Delegation — Multi-City Ground Transport</div>
        </div>
        <div class="case-study-card__body">
          <p class="case-study-card__text">Secure ground transport coordination for a 40-person international sports delegation across three Australian cities during a major tournament — airports, venues, accommodation and team movements managed end-to-end.</p>
          <span class="case-study-card__cta" style="color:var(--gold);">Coming Soon</span>
        </div>
      </div>
    </div>

    <div style="margin-top:2rem; text-align:center;">
      <a href="/articles/" class="btn btn--outline-navy">View All Case Studies & Testimonials</a>
    </div>
  </div>
</section>

<CtaBand
  ariaLabel="Event Solutions CTA"
  title="Planning an Event?"
  body="Our team can provide a confidential consultation, risk assessment and tailored proposal for your event — from a 20-person boardroom function to a 20,000-person public event, or a major film or television production."
  primary={{ label: 'Request a Consultation', href: '/contact/' }}
  outline={{ label: 'View Tourism Solutions', href: '/services/' }}
/>

<FooterAfs />
<SiteFooter />

</BaseLayout>
