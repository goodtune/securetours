---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import FooterAfs from '../components/FooterAfs.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CtaBand from '../components/CtaBand.astro';
import PageHero from '../components/PageHero.astro';
import { resources as page } from '../lib/pages';
---
<BaseLayout
  title={page.meta.title}
  description={page.meta.description}
  canonical="https://securetours.com.au/resources/"
>

<SiteNav active="resources" />

<PageHero
  ariaLabel="Resources hero"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Resources' },
  ]}
  label={page.hero.label}
  title={page.hero.title}
  sub={page.hero.sub}
/>

<section class="section" aria-labelledby="resources-heading">
  <div class="container">
    <h2 id="resources-heading" class="sr-only">{page.library_heading}</h2>

    {page.categories.map((cat) => (
      <div class="downloads-category">
        <h3>{cat.heading}</h3>
        {cat.note && (
          <p style="font-size:0.9rem; color:var(--gray-700); margin-bottom:1.25rem;">{cat.note}</p>
        )}
        <div class="downloads-grid">
          {cat.cards.map((card) =>
            card.href ? (
              <a class="download-card download-card--live" href={card.href} target="_blank" rel="noopener" aria-label={card.aria_label}>
                <div class="download-card__icon">📄</div>
                <div class="download-card__body">
                  <div class="download-card__name">{card.name}</div>
                  <div class="download-card__meta">{card.meta}</div>
                </div>
                <div class="download-card__badge download-card__badge--live">{card.badge}</div>
              </a>
            ) : (
              <div class="download-card">
                <div class="download-card__icon">📄</div>
                <div class="download-card__body">
                  <div class="download-card__name">{card.name}</div>
                  <div class="download-card__meta">{card.meta}</div>
                </div>
                <div class="download-card__badge">{card.badge}</div>
              </div>
            ),
          )}
        </div>
        {cat.footnote && <p class="coming-soon-note" set:html={cat.footnote} />}
      </div>
    ))}

  </div>
</section>

<CtaBand
  ariaLabel="Resources CTA"
  title={page.cta_band.title}
  body={page.cta_band.body}
  primary={page.cta_band.primary}
  outline={page.cta_band.outline}
/>

<FooterAfs />
<SiteFooter />

<style is:global>
  .downloads-category {
    margin-bottom: 3rem;
  }
  .downloads-category h3 {
    font-size: 1.1rem;
    color: var(--navy);
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--gold);
    margin-bottom: 1.25rem;
  }
  .downloads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 1rem;
  }
  .download-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--off-white);
    border: 1px solid var(--gray-300);
    border-radius: var(--radius);
    padding: 1.1rem 1.5rem;
    transition: var(--transition);
    text-decoration: none;
    color: inherit;
  }
  .download-card:hover {
    border-color: var(--gold);
    background: var(--white);
    box-shadow: var(--shadow);
  }
  .download-card--live { border-color: rgba(184,149,42,0.3); }
  .download-card--live:hover { border-color: var(--gold); }
  .download-card__icon { font-size: 2rem; flex-shrink: 0; }
  .download-card__body { flex: 1; min-width: 0; }
  .download-card__name {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--navy);
    line-height: 1.4;
  }
  .download-card__meta {
    font-size: 0.75rem;
    color: var(--gray-500);
    margin-top: 0.2rem;
  }
  .download-card__badge {
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(184,149,42,0.85);
    background: rgba(184,149,42,0.08);
    border: 1px solid rgba(184,149,42,0.25);
    border-radius: 3px;
    padding: 0.2rem 0.5rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .download-card__badge--live {
    color: #1a6e3c;
    background: rgba(26,110,60,0.08);
    border-color: rgba(26,110,60,0.25);
  }
  .coming-soon-note {
    background: var(--off-white);
    border-left: 3px solid var(--gold);
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius);
    color: var(--navy);
    font-size: 0.9rem;
    margin-top: 1.5rem;
  }
</style>

</BaseLayout>
