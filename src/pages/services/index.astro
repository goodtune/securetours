---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import FooterAfs from '../../components/FooterAfs.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageHero from '../../components/PageHero.astro';
import { servicesIndex as page } from '../../lib/pages';
---
<BaseLayout
  title={page.meta.title}
  description={page.meta.description}
  canonical="https://securetours.com.au/services/"
>

<SiteNav active="services" />

<PageHero
  ariaLabel="Solutions overview hero"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Tourism Solutions' },
  ]}
  label={page.hero.label}
  title={page.hero.title}
  sub={page.hero.sub}
/>

<section class="section" aria-labelledby="svc-heading">
  <div class="container">

    <div class="solutions-featured">
      <div class="solutions-featured__body">
        <span class="solutions-featured__tag">{page.featured.tag}</span>
        <h2 class="solutions-featured__title">{page.featured.title}</h2>
        <p class="solutions-featured__text">{page.featured.text}</p>
        <a href={page.featured.href} class="btn btn--primary">{page.featured.cta_label}</a>
      </div>
      <div class="solutions-featured__cta">
        <div style="font-size:4rem; opacity:0.2;">{page.featured.icon}</div>
      </div>
    </div>

    <div class="services-grid" id="svc-heading">
      {page.cards.map((c) => (
        <article class="service-card">
          <div class="service-card__icon" aria-hidden="true">{c.icon}</div>
          <h2 class="service-card__title">{c.title}</h2>
          <p class="service-card__text">{c.body}</p>
          <a href={c.href} class="service-card__link">{page.card_link_label}</a>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="cta-band">
  <div class="container">
    <h2>{page.cta_band.title}</h2>
    <p>{page.cta_band.body}</p>
    <div class="btn-group">
      <a href={page.cta_band.button.href} class="btn btn--primary">{page.cta_band.button.label}</a>
    </div>
  </div>
</section>

<FooterAfs />
<SiteFooter showAbn={false} showLocation={false} showLegal={false} />

</BaseLayout>
