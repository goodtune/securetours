---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import FooterAfs from '../components/FooterAfs.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CtaBand from '../components/CtaBand.astro';
import PageHero from '../components/PageHero.astro';

const services = (await getCollection('services'))
  .filter((s) => !s.data.coming_soon)
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="Contact — Secure Tours & Travel"
  description="Get in touch with Secure Tours & Travel. Enquiries welcome in multiple languages. Australia-wide operations."
  canonical="https://securetours.com.au/contact/"
>

<SiteNav active="contact" />

<PageHero
  ariaLabel="Contact hero"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Contact' },
  ]}
  label=""
  title="Get in Touch"
  sub="Our team is ready to assist with enquiries, bookings and custom itinerary planning."
/>

<section class="section" aria-labelledby="contact-heading">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <span class="section-label">Contact</span>
        <h2 id="contact-heading">Contact Information</h2>
        <div class="gold-rule"></div>
        <p>Secure Tours & Travel operates nationally across Australia. Reach us directly — we respond to all enquiries within one business day.</p>

        <div class="contact-detail">
          <div class="contact-detail__item">
            <span class="contact-detail__icon" aria-hidden="true">📞</span>
            <div class="contact-detail__text">
              <strong>Phone</strong><br />
              <a href="tel:+61414499778">+61 414 499 778</a>
            </div>
          </div>
          <div class="contact-detail__item">
            <span class="contact-detail__icon" aria-hidden="true">✉️</span>
            <div class="contact-detail__text">
              <strong>Email</strong><br />
              <a href="mailto:enquiries@securetours.com.au">enquiries@securetours.com.au</a>
            </div>
          </div>
          <div class="contact-detail__item">
            <span class="contact-detail__icon" aria-hidden="true">📍</span>
            <div class="contact-detail__text">
              <strong>Location</strong><br />
              <span>Australia-wide · Based in NSW</span>
            </div>
          </div>
        </div>

        <div style="margin-top:2rem; padding:1.25rem; background:var(--gold-pale); border-left:3px solid var(--gold); border-radius:var(--radius);">
          <p style="font-size:0.875rem; color:var(--navy); margin:0;">Enquiries welcome in multiple languages — including English, Mandarin, French, Korean, Italian and German</p>
        </div>
      </div>

      <div>
        <div class="contact-form" id="form-container">
          <form id="contact-form" method="post" action="#" novalidate>
            <div class="form-row">
              <div class="form-group">
                <label for="first_name">First Name</label>
                <input type="text" id="first_name" name="first_name" required autocomplete="given-name" />
              </div>
              <div class="form-group">
                <label for="last_name">Last Name</label>
                <input type="text" id="last_name" name="last_name" required autocomplete="family-name" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" required autocomplete="email" />
              </div>
              <div class="form-group">
                <label for="phone">Phone Number</label>
                <input type="tel" id="phone" name="phone" autocomplete="tel" />
              </div>
            </div>
            <div class="form-group">
              <label for="service">Solution of Interest</label>
              <select id="service" name="service">
                <option value="">Select a solution…</option>
                {services.map((s) => (
                  <option value={s.id}>{s.data.title}</option>
                ))}
                <option value="general">General Enquiry</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Your Message</label>
              <textarea id="message" name="message" rows="5" required></textarea>
            </div>
            <button type="submit" class="btn btn--primary" style="width:100%; justify-content:center;">Send Enquiry</button>
          </form>

          <div id="form-success" hidden>
            <h3>✓ Enquiry Received</h3>
            <p>Thanks for your enquiry — we'll be back in touch within 48–72 hours.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form');
    const success = document.getElementById('form-success');
    if (!form || !success) return;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      form.hidden = true;
      success.hidden = false;
      success.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  });
</script>

<CtaBand
  ariaLabel="Contact CTA"
  primary={{ label: 'View All Solutions', href: '/services/' }}
  outline={{ label: 'About Us', href: '/about/' }}
/>

<FooterAfs />
<SiteFooter showAbn={false} showLocation={false} showLegal={false} />

</BaseLayout>
