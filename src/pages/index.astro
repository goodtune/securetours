---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import FooterAfs from '../components/FooterAfs.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CtaBand from '../components/CtaBand.astro';
import ServiceCard from '../components/ServiceCard.astro';
import SolutionsFeatured from '../components/SolutionsFeatured.astro';

const services = await getCollection('services');
const tours = await getEntry('services', 'tours-travel-solutions');

const gridServices = services
  .filter((s) => s.id !== 'tours-travel-solutions')
  .sort((a, b) => a.data.order - b.data.order);

if (!tours) throw new Error('Featured service "tours-travel-solutions" missing from collection');
---
<BaseLayout
  title="Secure Tours & Travel — Secure Luxury Travel for Discerning Individuals & Groups"
  description="Australia's premier secure travel and VIP concierge specialists. Combining elite security expertise with luxury service across inbound tourism, executive transfers, athlete support, and event management."
  canonical="https://securetours.com.au/"
>

<SiteNav active="home" />

<section class="hero" id="home" aria-label="Hero">
  <div class="container">
    <div class="hero-content">
      <span class="hero-tag">Australia's Premium Secure Travel Specialists</span>
      <h1>Secure Luxury Travel for <em>Discerning Individuals</em> & Groups</h1>
      <p class="hero-sub">Combining elite security expertise with premium concierge service — we protect your journey, from first arrival to final departure.</p>
      <div class="hero-actions">
        <a href="/services/" class="btn btn--primary">Explore Our Solutions</a>
        <a href="/contact/" class="btn btn--outline">Enquire Now</a>
      </div>
      <img src="/assets/tagline.gif" alt="Secure Luxury Travel for discerning individuals & groups" class="hero-tagline-img" loading="lazy" />
    </div>
  </div>
</section>

<div class="stats-bar" aria-label="Key facts">
  <div class="container">
    <div class="stats-inner">
      <div class="stat-item">
        <div class="stat-item__number">37 Years</div>
        <div class="stat-item__label">Industry Experience</div>
      </div>
      <div class="stat-item">
        <div class="stat-item__number">Est. 1989</div>
        <div class="stat-item__label">Australian Frontline Solutions</div>
      </div>
      <div class="stat-item">
        <div class="stat-item__number">National</div>
        <div class="stat-item__label">Footprint (NSW · QLD · VIC)</div>
      </div>
      <div class="stat-item">
        <div class="stat-item__number">24/7</div>
        <div class="stat-item__label">Support Available</div>
      </div>
    </div>
  </div>
</div>

<section class="section section--alt" id="services" aria-labelledby="services-heading">
  <div class="container">
    <span class="section-label">Our Solutions</span>
    <h2 class="section-title" id="services-heading">Specialist Solutions</h2>
    <div class="gold-rule"></div>
    <p class="section-intro">Every solution is designed around one principle: your safety, comfort and peace of mind. From private transfers to full event logistics, we cover every detail.</p>

    <SolutionsFeatured
      tag="Flagship Solution · Inbound & Domestic"
      title={tours.data.title}
      body={tours.data.home_card.body}
      cta={{ label: 'Learn More', href: '/services/tours-travel-solutions/' }}
      icon={tours.data.home_card.icon}
    />

    <div class="services-grid">
      {gridServices.map((s) => (
        <ServiceCard
          icon={s.data.home_card.icon}
          title={s.data.home_card.title ?? s.data.title}
          body={s.data.home_card.body}
          href={s.data.coming_soon ? undefined : `/services/${s.id}/`}
          badge={s.data.coming_soon ? 'Coming Soon' : undefined}
          ariaLabel={s.data.coming_soon ? `${s.data.title} — coming soon` : undefined}
        />
      ))}
      <ServiceCard
        icon="✦"
        title="New Solution"
        body="Additional specialist solutions are being finalised. Contact us to discuss your specific requirements."
        badge="Coming Soon"
        ariaLabel="New solution coming soon"
      />
    </div>
  </div>
</section>

<section class="section" id="about" aria-labelledby="about-heading">
  <div class="container">
    <div class="about-grid">
      <div class="about-text">
        <span class="section-label">About Secure Tours & Travel</span>
        <h2 id="about-heading">Built on Trust. Backed by Experience.</h2>
        <div class="gold-rule"></div>
        <p>Secure Tours & Travel is the dedicated tourism and event services division of Australian Frontline Solutions (AFS) — one of Australia's most trusted names in safety leadership, protective operations and event management.</p>
        <ul class="about-features">
          <li>Security Master Licence holder</li>
          <li>Multilingual teams — a range of languages</li>
          <li>Discreet, professional, reliable</li>
          <li>National coverage — global partnerships</li>
          <li>Sibling brand to Athlete Pathways Australia</li>
        </ul>
        <a href="/about/" class="btn btn--navy" style="margin-top:2rem;">Our Story</a>
      </div>
      <div class="about-visual">
        <div class="about-badge">
          <div class="about-badge__number">37</div>
          <div class="about-badge__label">Years of Excellence</div>
          <div style="margin-top:1.5rem; border-top: 1px solid rgba(184,149,42,0.3); padding-top:1.5rem;">
            <p style="font-size:0.875rem; color:rgba(255,255,255,0.7); line-height:1.7; margin:0 0 0.75rem;">Australian Frontline Solutions — established 1989.</p>
            <p style="font-size:0.775rem; color:rgba(184,149,42,0.8); font-weight:600; letter-spacing:0.04em; text-transform:uppercase; margin:0;">Security Master Licence Holder</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section section--alt" aria-labelledby="why-heading">
  <div class="container text-center">
    <span class="section-label">Why Choose Us</span>
    <h2 id="why-heading">What Sets Us Apart</h2>
    <div class="gold-rule"></div>
    <div class="why-grid">
      <div class="why-item">
        <span class="why-item__icon" aria-hidden="true">🛡️</span>
        <h3>Security-First</h3>
        <p>Every journey is underpinned by licensed risk assessment, advance reconnaissance and close protection protocols.</p>
      </div>
      <div class="why-item">
        <span class="why-item__icon" aria-hidden="true">👑</span>
        <h3>White-Glove Service</h3>
        <p>From airport arrivals to VIP event access — our concierge teams ensure seamless, stress-free experiences.</p>
      </div>
      <div class="why-item">
        <span class="why-item__icon" aria-hidden="true">🌐</span>
        <h3>Multilingual</h3>
        <p>We speak your language. Our chaperones and documentation are available across a range of languages including English, Mandarin, French, Korean, Italian and German.</p>
      </div>
      <div class="why-item">
        <span class="why-item__icon" aria-hidden="true">📞</span>
        <h3>24/7 Support</h3>
        <p>Round-the-clock support for international clients across all time zones.</p>
      </div>
    </div>
  </div>
</section>

<CtaBand headingId="cta-heading" />

<FooterAfs />
<SiteFooter />

</BaseLayout>
