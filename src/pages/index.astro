---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import FooterAfs from '../components/FooterAfs.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CtaBand from '../components/CtaBand.astro';
import ServiceCard from '../components/ServiceCard.astro';
import SolutionsFeatured from '../components/SolutionsFeatured.astro';
import AboutBadge from '../components/AboutBadge.astro';
import { home } from '../lib/pages';

const services = await getCollection('services');
const tours = await getEntry('services', 'tours-travel-solutions');

const gridServices = services
  .filter((s) => s.id !== 'tours-travel-solutions')
  .sort((a, b) => a.data.order - b.data.order);

if (!tours) throw new Error('Featured service "tours-travel-solutions" missing from collection');
---
<BaseLayout
  title={home.meta.title}
  description={home.meta.description}
  canonical="https://securetours.com.au/"
>

<SiteNav active="home" />

<section class="hero" id="home" aria-label="Hero">
  <div class="container">
    <div class="hero-content">
      <span class="hero-tag">{home.hero.tag}</span>
      <h1 set:html={home.hero.title} />
      <p class="hero-sub">{home.hero.sub}</p>
      <div class="hero-actions">
        <a href={home.hero.cta_primary.href} class="btn btn--primary">{home.hero.cta_primary.label}</a>
        <a href={home.hero.cta_secondary.href} class="btn btn--outline">{home.hero.cta_secondary.label}</a>
      </div>
      <img src="/assets/tagline.gif" alt="Secure Luxury Travel for discerning individuals & groups" class="hero-tagline-img" loading="lazy" />
    </div>
  </div>
</section>

<div class="stats-bar" aria-label="Key facts">
  <div class="container">
    <div class="stats-inner">
      {home.stats.map((stat) => (
        <div class="stat-item">
          <div class="stat-item__number">{stat.number}</div>
          <div class="stat-item__label">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</div>

<section class="section section--alt" id="services" aria-labelledby="services-heading">
  <div class="container">
    <span class="section-label">{home.solutions.label}</span>
    <h2 class="section-title" id="services-heading">{home.solutions.title}</h2>
    <div class="gold-rule"></div>
    <p class="section-intro">{home.solutions.intro}</p>

    <SolutionsFeatured
      tag={home.solutions.featured_tag}
      title={tours.data.title}
      body={tours.data.home_card.body}
      cta={{ label: home.solutions.featured_cta_label, href: '/services/tours-travel-solutions/' }}
      icon={tours.data.home_card.icon}
    />

    <div class="services-grid">
      {gridServices.map((s) => (
        <ServiceCard
          icon={s.data.home_card.icon}
          title={s.data.home_card.title ?? s.data.title}
          body={s.data.home_card.body}
          href={s.data.coming_soon ? undefined : `/services/${s.id}/`}
          badge={s.data.coming_soon ? 'Coming Soon' : undefined}
          ariaLabel={s.data.coming_soon ? `${s.data.title} — coming soon` : undefined}
        />
      ))}
    </div>
  </div>
</section>

<section class="section" id="about" aria-labelledby="about-heading">
  <div class="container">
    <div class="about-grid">
      <div class="about-text">
        <span class="section-label">{home.about.label}</span>
        <h2 id="about-heading">{home.about.title}</h2>
        <div class="gold-rule"></div>
        <p>{home.about.text}</p>
        <ul class="about-features">
          {home.about.features.map((feature) => <li>{feature}</li>)}
        </ul>
        <a href="/about/" class="btn btn--navy" style="margin-top:2rem;">{home.about.cta_label}</a>
      </div>
      <div class="about-visual">
        <AboutBadge
          number={home.about.badge.number}
          label={home.about.badge.label}
          footnote={home.about.badge.footnote}
          footnoteTag={home.about.badge.footnote_tag}
        />
      </div>
    </div>
  </div>
</section>

<section class="section section--alt" aria-labelledby="why-heading">
  <div class="container text-center">
    <span class="section-label">{home.why.label}</span>
    <h2 id="why-heading">{home.why.title}</h2>
    <div class="gold-rule"></div>
    <div class="why-grid">
      {home.why.items.map((item) => (
        <div class="why-item">
          <span class="why-item__icon" aria-hidden="true">{item.icon}</span>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<CtaBand headingId="cta-heading" />

<FooterAfs />
<SiteFooter />

</BaseLayout>
