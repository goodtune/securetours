---
import BaseLayout from '../layouts/BaseLayout.astro';
import { notFound as page } from '../lib/pages';
---
<BaseLayout
  title={page.meta.title}
  description={page.meta.description}
>
  <div class="error-page">
    <div class="error-content">
      <div class="error-code">404</div>
      <h1>{page.title}</h1>
      <p>{page.body}</p>
      <div class="error-actions">
        <a href={page.primary.href} class="btn btn--primary">{page.primary.label}</a>
        <a href={page.outline.href} class="btn btn--outline">{page.outline.label}</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .error-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 100%);
    padding: 2rem;
    text-align: center;
  }
  .error-content { max-width: 520px; }
  .error-code {
    font-family: var(--font-serif);
    font-size: clamp(5rem, 15vw, 9rem);
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 0.5rem;
    opacity: 0.6;
  }
  .error-content h1 { color: var(--white); margin-bottom: 1rem; }
  .error-content p { color: rgba(255,255,255,0.7); margin-bottom: 2rem; }
  .error-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
</style>
