---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import FooterAfs from '../components/FooterAfs.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CtaBand from '../components/CtaBand.astro';
import PageHero from '../components/PageHero.astro';
import Faq from '../components/Faq.astro';

const generalFaqs = [
  { question: 'What is Secure Tours and Travel and who is it for?', answer: 'TBD' },
  { question: 'Is Secure Tours and Travel a licensed security company?', answer: 'TBD' },
  { question: 'Are your staff trained in security or are they just drivers and escorts?', answer: 'TBD' },
  { question: 'Do you operate outside of New South Wales?', answer: 'TBD' },
  { question: 'Can you arrange services at short notice?', answer: 'TBD' },
  { question: 'How do I get a quote?', answer: 'TBD' },
  { question: 'Do you work with international clients who are not yet in Australia?', answer: 'TBD' },
  { question: 'What languages do your team members speak?', answer: 'TBD' },
];
---
<BaseLayout
  title="Frequently Asked Questions — Secure Tours & Travel"
  description="Answers to the most common questions about Secure Tours & Travel — licensing, staff training, coverage, languages and how to enquire."
  canonical="https://securetours.com.au/faq/"
>

<SiteNav />

<PageHero
  ariaLabel="FAQ hero"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Frequently Asked Questions' },
  ]}
  label="Trust · Booking · Coverage"
  title="Frequently Asked Questions"
  sub="Common questions about Secure Tours & Travel — who we are, how we operate, and how to engage us. Service-specific questions live on each solution's page."
/>

<section class="section">
  <Faq
    items={generalFaqs}
    heading=""
    ariaLabel="General FAQs"
    variant="plain"
  />
</section>

<CtaBand
  title="Still have questions?"
  body="Our team is happy to discuss your specific requirements — corporate, family, sports, performing arts, or compassionate travel."
  primary={{ label: 'Get in Touch', href: '/contact/' }}
  outline={{ label: 'View All Solutions', href: '/services/' }}
/>

<FooterAfs />
<SiteFooter />

</BaseLayout>
