---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import FooterAfs from '../components/FooterAfs.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CtaBand from '../components/CtaBand.astro';
import PageHero from '../components/PageHero.astro';
import Faq from '../components/Faq.astro';
import { faq as page } from '../lib/pages';
---
<BaseLayout
  title={page.meta.title}
  description={page.meta.description}
  canonical="https://securetours.com.au/faq/"
>

<SiteNav />

<PageHero
  ariaLabel="FAQ hero"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Frequently Asked Questions' },
  ]}
  label={page.hero.label}
  title={page.hero.title}
  sub={page.hero.sub}
/>

<section class="section">
  <Faq
    items={page.faqs}
    heading=""
    ariaLabel="General FAQs"
    variant="plain"
  />
</section>

<CtaBand
  title={page.cta_band.title}
  body={page.cta_band.body}
  primary={page.cta_band.primary}
  outline={page.cta_band.outline}
/>

<FooterAfs />
<SiteFooter />

</BaseLayout>
