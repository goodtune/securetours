---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import FooterAfs from '../components/FooterAfs.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CtaBand from '../components/CtaBand.astro';
import PageHero from '../components/PageHero.astro';
import AboutBadge from '../components/AboutBadge.astro';
import { about } from '../lib/pages';
---
<BaseLayout
  title={about.meta.title}
  description={about.meta.description}
  canonical="https://securetours.com.au/about/"
>

<SiteNav active="about" />

<PageHero
  ariaLabel="About page hero"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'About Us' },
  ]}
  label={about.hero.label}
  title={about.hero.title}
  sub={about.hero.sub}
/>

<section class="section" aria-labelledby="who-heading">
  <div class="container">
    <div class="about-grid">
      <div>
        <span class="section-label">{about.who.label}</span>
        <h2 id="who-heading">{about.who.title}</h2>
        <div class="gold-rule"></div>
        <p class="service-lead">{about.who.lead}</p>
      </div>
      <div class="about-visual">
        <AboutBadge
          number={about.who.badge.number}
          label={about.who.badge.label}
          footnote={about.who.badge.footnote}
          borderTop={false}
        />
      </div>
    </div>
  </div>
</section>

<section class="section section--alt" aria-labelledby="values-heading">
  <div class="container">
    <span class="section-label">{about.values.label}</span>
    <h2 id="values-heading">{about.values.title}</h2>
    <div class="gold-rule"></div>
    <div class="values-grid">
      {about.values.items.map((v) => (
        <div class="value-card">
          <h3>{v.title}</h3>
          <p>{v.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section" aria-labelledby="clients-heading">
  <div class="container">
    <span class="section-label">{about.clients.label}</span>
    <h2 id="clients-heading">{about.clients.title}</h2>
    <div class="gold-rule"></div>
    <div class="clients-grid">
      {about.clients.items.map((c) => <div class="client-chip">{c}</div>)}
    </div>
  </div>
</section>

<section class="section section--navy" aria-labelledby="parent-heading">
  <div class="container">
    <div class="parent-brand">
      <div>
        <span class="section-label">{about.parent.label}</span>
        <h2 id="parent-heading">{about.parent.title}</h2>
        <div class="gold-rule"></div>
        <p class="section-intro">{about.parent.intro}</p>
        <a href="/contact/" class="btn btn--primary" style="margin-top:2rem;">{about.parent.cta_label}</a>
      </div>
      <div>
        <div class="afs-creds">
          {about.parent.creds.map((c) => (
            <div class="afs-cred-item">
              <div class="afs-cred-item__value">{c.value}</div>
              <div class="afs-cred-item__label">{c.label}</div>
            </div>
          ))}
          <div class="afs-cred-item" style="grid-column: span 2;">
            <div class="afs-cred-item__value" style="font-size:1rem; letter-spacing:0.03em;">{about.parent.creds_wide.value}</div>
            <div class="afs-cred-item__label">{about.parent.creds_wide.label}</div>
          </div>
        </div>
        <div style="background:rgba(255,255,255,0.06); border-radius: 8px; padding:2rem; border:1px solid rgba(184,149,42,0.25); margin-top:1rem;">
          <ul class="about-features" style="color:rgba(255,255,255,0.85);">
            {about.parent.features.map((f) => (
              <li style="border-color:rgba(255,255,255,0.1); color:rgba(255,255,255,0.85);">{f}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<CtaBand headingId="about-cta-heading" />

<FooterAfs />
<SiteFooter showAbn={false} showLocation={false} showLegal={false} />

<style is:global>
  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .value-card {
    background: var(--off-white);
    border-left: 4px solid var(--gold);
    padding: 1.75rem;
    border-radius: var(--radius);
  }
  .value-card h3 { font-size: 1.05rem; margin-bottom: 0.6rem; }
  .value-card p { font-size: 0.9rem; color: var(--gray-700); margin: 0; }
  .clients-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }
  .client-chip {
    background: var(--navy);
    color: rgba(255,255,255,0.85);
    padding: 1rem 1.25rem;
    border-radius: var(--radius);
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .client-chip::before { content: '✦'; color: var(--gold); flex-shrink: 0; }
  .parent-brand {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    margin-top: 2rem;
  }
  @media (max-width: 700px) {
    .parent-brand { grid-template-columns: 1fr; gap: 2rem; }
  }
  .afs-creds {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
  }
  .afs-cred-item {
    background: rgba(184,149,42,0.08);
    border: 1px solid rgba(184,149,42,0.2);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    text-align: center;
  }
  .afs-cred-item__value {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--gold);
    font-weight: 700;
    line-height: 1;
  }
  .afs-cred-item__label {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.6);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-top: 0.35rem;
  }
  @media (max-width: 480px) { .afs-creds { grid-template-columns: 1fr; } }
</style>

</BaseLayout>
