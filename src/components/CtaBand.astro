---
export interface Props {
  title?: string;
  body?: string;
  primary?: { label: string; href: string };
  outline?: { label: string; href: string };
  headingId?: string;
  ariaLabel?: string;
}

const {
  title = 'Ready to Travel with Confidence?',
  body = 'Our team is available to tailor a solution for individuals, groups, corporate delegations and touring professionals.',
  primary = { label: 'Get in Touch', href: '/contact/' },
  outline = { label: 'View All Solutions', href: '/services/' },
  headingId,
  ariaLabel,
} = Astro.props;
---
<section
  class="cta-band"
  aria-labelledby={headingId}
  aria-label={ariaLabel}
>
  <div class="container">
    <h2 id={headingId}>{title}</h2>
    <p>{body}</p>
    <div class="btn-group">
      <a href={primary.href} class="btn btn--primary">{primary.label}</a>
      <a href={outline.href} class="btn btn--outline">{outline.label}</a>
    </div>
  </div>
</section>
