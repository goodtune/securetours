---
import { site } from '../lib/pages';

export interface Props {
  title?: string;
  body?: string;
  primary?: { label: string; href: string };
  outline?: { label: string; href: string };
  headingId?: string;
  ariaLabel?: string;
}

const {
  title = site.cta_band.title,
  body = site.cta_band.body,
  primary = site.cta_band.primary,
  outline = site.cta_band.outline,
  headingId,
  ariaLabel,
} = Astro.props;
---
<section
  class="cta-band"
  aria-labelledby={headingId}
  aria-label={ariaLabel}
>
  <div class="container">
    <h2 id={headingId}>{title}</h2>
    <p>{body}</p>
    <div class="btn-group">
      <a href={primary.href} class="btn btn--primary">{primary.label}</a>
      <a href={outline.href} class="btn btn--outline">{outline.label}</a>
    </div>
  </div>
</section>
