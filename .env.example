# Template for local development. Copy to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.
#
# In production these are set as encrypted env vars on the DO App Platform
# contact-api service component (managed in the DO dashboard).

# Resend transactional email API. Get a key at https://resend.com/api-keys.
# Used by the contact-form Node service to send enquiry notifications to
# enquiries@securetours.com.au.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Where the contact form delivers enquiries to. Routed onward to Matt by
# the ImprovMX alias on securetours.com.au (configured separately).
CONTACT_TO_ADDRESS=enquiries@securetours.com.au

# The verified-on-Resend "from" address for outbound mail. Must be on a
# domain whose DKIM/SPF/DMARC records have been verified in Resend.
CONTACT_FROM_ADDRESS=noreply@securetours.com.au
